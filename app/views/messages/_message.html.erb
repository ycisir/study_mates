<div class="mb-2">
	<%= link_to message.user.name, user_path(message.user), class: "text-decoration-none small" %> : <%= message.body %>

	<% if message.files.attached? %>
        <div class="d-flex flex-wrap gap-2">
        	<% message.files.each do |file| %>

          	<% if file.image? %>
            	<%= link_to url_for(file), target: "_blank" do %>
              		<%= image_tag url_for(file.variant(:thumb)) %>
            	<% end %>

          		<% else %>
            		<%= link_to file.filename.to_s, url_for(file), target: "_blank", class: "text-decoration-none d-block" %>
          		<% end %>
        	<% end %>
      	</div>
    <% end %>

    <div class="text-muted" style="font-size: 0.7rem;">
        <em><%= time_ago_in_words(message.created_at) %> ago</em>
    </div>
</div>
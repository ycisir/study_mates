<%= content_for(:title, @user.name) %>


<div class="row">
	<div class="col-md-9 shadow-sm px-5 pt-5 pb-2">
		<div class="text-center mb-3">
			<%= image_tag @user.avatar_thumbnail, class: "rounded-circle", width: "100" if @user.avatar.attached? %>
			<h4 class="mt-3">Hey, <%= @user.name %></h4>
			<%= link_to "Edit profile", edit_user_registration_path, class: "btn btn-sm btn-outline-primary" if current_user == @user %>
		</div>

		<span class="fw-semibold small">
			<% if current_user == @user %>
				Rooms you created:
			<% else %>
				Rooms created by <%= @user.name %>:
			<% end %>
		</span>
		<% @rooms.each do |room| %>

		    <div class="card-body border p-3 mb-3 rounded">

		      <!-- Header -->
		      <div class="d-flex justify-content-between align-items-center mb-2">
		        <small class="text-muted">
		          <%= time_ago_in_words(room.created_at) %> ago
		        </small>
		      </div>

		      <!-- Room Title -->
		      <h4 class="fw-semibold mb-2">
		        <%= link_to room.name, room_path(room), class: "text-decoration-none text-dark" %>
		      </h4>

		      <!-- Footer -->
		      <div class="d-flex justify-content-between align-items-center">

		        <small class="text-muted">
		          <i class="bi bi-people me-1"></i>
		          <%# pluralize(room.participants.uniq.count, "participant") %>
		          Participants
		        </small>

		        <span class="badge bg-secondary-subtle text-dark">
		          <%= room.topic.name %>
		        </span>

		      </div>

		    </div>

		<% end %>
		<%= will_paginate @rooms, class: "pagination justify-content-center" %>
	</div>

	<div class="col-md-3">
		<% if user_signed_in? && current_user == @user %>
	      <div class="card border-0 shadow-sm rounded-3">
	        <div class="card-body">

	          <h6 class="fw-semibold mb-3">
	            <i class="bi bi-activity me-2"></i>Your Activity
	          </h6>

	          <%# render "activity" %>

	          <ul class="list-group list-group-flush">
	            <li class="list-group-item px-0 small">
	              @alex joined Ruby Room
	            </li>
	            <li class="list-group-item px-0 small">
	              New message in Rails Room
	            </li>
	            <li class="list-group-item px-0 small">
	              @sam created JavaScript Room
	            </li>
	          </ul>

	        </div>
	      </div>
	    <% else %>

	    Sign up to see activity
	   	<% end %>

	</div>
</div>

<% @rooms.each do |room| %>

  <div class="card shadow-sm border-0 mb-4">
    <div class="card-body p-4">

      <!-- Header -->
      <div class="d-flex justify-content-between align-items-center mb-2">
        <small class="text-muted">
          Created by
          <%= link_to room.user.name, profile_path(room.user), class: "text-decoration-none fw-medium text-dark" %>
        </small>

        <small class="text-muted">
          <%= time_ago_in_words(room.created_at) %> ago
        </small>
      </div>

      <!-- Room Title -->
      <h4 class="fw-semibold mb-2">
        <%= link_to room.name, room_path(room), class: "text-decoration-none text-dark" %>
      </h4>

      <!-- Description -->
      <p class="text-muted mb-3">
        <%= truncate(room.description, length: 80) %>
      </p>

      <hr class="my-3">

      <!-- Footer -->
      <div class="d-flex justify-content-between align-items-center">

        <small class="text-muted">
          <i class="bi bi-people me-1"></i>
          <%# pluralize(room.participants.uniq.count, "participant") %>
          Participant
        </small>

        <span class="badge bg-secondary-subtle text-dark">
          <%= room.topic.name %>
        </span>

      </div>

    </div>
  </div>

<% end %>
<%= will_paginate @rooms, class: "pagination justify-content-center" %>

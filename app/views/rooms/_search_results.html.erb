<ul class="search-dropdown list-group">
<% rooms.each do |room| %>
  <li class="list-group-item">
    <%= link_to room.name, room_path(room), class: "text-decoration-none text-dark" %>
  </li>
<% end %>
</ul>


<style>
	#search_results {
	  position: absolute; /* Makes it float over the page */
	  top: 100%;          /* Right below the search field */
	  left: 0;
	  width: 100%;
	  max-height: 200px;  /* Adjust for number of visible items */
	  overflow-y: auto;
	  z-index: 1000;
	  background: white;
	  border-radius: 0 0 4px 4px;
	  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
	}

	.search-dropdown {
	  margin: 0;
	  padding: 0;
	  list-style: none;
	}

	.search-dropdown .list-group-item {
	  padding: 8px 12px;
	  cursor: pointer;
	}

	.search-dropdown .list-group-item:hover {
	  background-color: #f0f0f0;
	}
</style>
<ul class="list-group list-group-flush">
    <% unless @topics.empty? %>
        <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
            <%= link_to "All", root_url, class: "text-decoration-none text-dark" %>
            <span class="badge text-bg-primary rounded-pill"><%= Room.count %></span>
        </li>
        <% @topics.each do |topic| %>
            <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                <%= link_to topic.name, rooms_path(topic_id: topic.id), class: "text-decoration-none text-dark" %>
                <span class="badge text-bg-primary rounded-pill"><%= topic.rooms.count %></span>
            </li>
        <% end %>

    <% end %>
</ul>
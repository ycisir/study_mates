<% @user ||= current_user %>
<div class="stats">
	<a href="<%= following_user_path(@user) %>" class="text-decoration-none small text-muted me-2">
		<strong id="following" class="stat">
		<%= @user.following.count %>
		</strong>
		following
	</a>
	<a href="<%= followers_user_path(@user) %>" class="text-decoration-none small text-muted">
		<strong id="followers" class="stat">
		<%= @user.followers.count %>
		</strong>
		followers
	</a>
</div>
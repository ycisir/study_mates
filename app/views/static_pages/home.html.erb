<div class="row">
	<div class="col-md-3">
		<%= render "topics" %>
	</div>
	<div class="col-md-6">
		<div class="d-flex justify-content-between align-items-center">
			<h5 class="fw-light">Rooms <small class="text-muted">(<%= @rooms.count %>)</small></h5>
			<% if signed_in? %>
				<%= link_to "Create room", new_room_path, class: "text-decoration-none" %>
			<% end %>
		</div>
		<%= render "rooms" %>
	</div>
	<div class="col-md-3">
		<h5 class="fw-light mb-3">Recent activity</h5>
		<ul id="recent-activity">
		  <% @messages.each do |message| %>
		    <%= render "static_pages/recent_activity", { message: message } %>
		  <% end %>
		</ul>
	</div>
</div>

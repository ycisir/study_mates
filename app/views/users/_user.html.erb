<li class="list-group-item d-flex justify-content-between align-items-center mt-3">

  <div class="d-flex align-items-center">
    <%= avatar_for(user, variant: :thumb, size: "20x20") %>
    <%= link_to user.name, user, class: "text-decoration-none small" %>
  </div>

  <% if signed_in? && current_user.admin? && !current_user?(user) %>
    <%= link_to "Delete", user,
        class: "text-decoration-none small",
        data: { "turbo-method": :delete, turbo_confirm: "Are you sure?" } %>
  <% end %>

</li>
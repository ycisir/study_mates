<% provide(:title, @user.name) %>
<div class="row">
	<aside class="col-md-4 mb-3">
		<%= render "profile" %>
		<section class="mt-3">
			<%= render 'shared/stats' %>
			<%= render 'follow_form' if signed_in? %>
		</section>
	</aside>

	<aside class="col-md-8">
		<h5 class="fw-light">Rooms <%= (signed_in? && current_user == @user) ? "you" : @user.name.downcase %> created (<%= @rooms.count %>)</h5>
		<%= render 'static_pages/rooms' %>
	</aside>
</div>